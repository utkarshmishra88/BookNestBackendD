server:
  port: 8085

spring:
  application:
    name: order-service

  datasource:
    url: jdbc:mysql://localhost:3306/booknest_order_service_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: password

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    open-in-view: false

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/
  instance:
    prefer-ip-address: true
    instance-id: ${spring.application.name}:${server.port}

jwt:
  # Must be same Base64 secret used in auth-service
  secret: YourSuperSecretKeyForBookNestPlatformEnsureItIsLongEnough

feign:
  client:
    config:
      default:
        connectTimeout: 5000
        readTimeout: 15000
        loggerLevel: basic

management:
  endpoints:
    web:
      exposure:
        include: health,info