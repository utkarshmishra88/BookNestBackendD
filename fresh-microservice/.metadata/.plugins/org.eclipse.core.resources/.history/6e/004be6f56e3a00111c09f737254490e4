server:
  port: 8087

spring:
  application:
    name: wallet-service

  datasource:
    url: jdbc:mysql://localhost:3306/booknest_wallet_service_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: password

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    open-in-view: false

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/

jwt:
  secret: YourSuperSecretKeyForBookNestPlatformEnsureItIsLongEnough

feign:
  client:
    config:
      default:
        connectTimeout: 5000
        readTimeout: 15000
        loggerLevel: basic

management:
  endpoints:
    web:
      exposure:
        include: health,info