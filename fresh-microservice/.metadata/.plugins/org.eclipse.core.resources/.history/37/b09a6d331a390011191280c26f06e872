spring:
  application:
    name: order-service
  cloud:
    openfeign:
      okhttp:
        enabled: true
  datasource:
    url: jdbc:mysql://localhost:3306/booknest_order_service_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: password
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true

server:
  port: 8085

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/