# Copy these into your environment before starting payment-service (PowerShell example below).
# Create Test keys: https://dashboard.razorpay.com/app/keys — use "Test Mode" keys (id starts with rzp_test_).
#
# PowerShell (current session):
#   $env:RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
#   $env:RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxx"
#
# Or set permanent User env vars: System Properties -> Environment Variables

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
